<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory android:title="Coordinate Display">
        <CheckBoxPreference
            android:key="show_altitude"
            android:title="Altitude"
            android:summary="Show altitude, meters above sea level"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_wgs84"
            android:title="WGS84"
            android:summary="Show Latitude/Longitude"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_rt90"
            android:title="RT90"
            android:summary="Show Swedish Grid (RT90)"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_sweref"
            android:title="SWEREF 99 TM"
            android:summary="Show SWEREF 99 TM coordinates"
            android:defaultValue="false" />

        <CheckBoxPreference
            android:key="show_rubin"
            android:title="RUBIN"
            android:summary="Show RUBIN grid reference"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_date"
            android:title="Date"
            android:summary="Show date in the ISO format"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_province"
            android:title="Province / landskap"
            android:summary="Look up landskap + lapmark from coordinate"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_district"
            android:title="District / socken"
            android:summary="Look up socken with the borders from 1935"
            android:defaultValue="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Species &amp; Collection Fields">

        <CheckBoxPreference
            android:key="show_species_field"
            android:title="Species name"
            android:summary="Show field for species name"
            android:defaultValue="true" />

        <PreferenceCategory android:title="Taxonomy &amp; Language">
            <CheckBoxPreference
                android:key="auto_resolve_synonyms"
                android:title="Auto-resolve Synonyms"
                android:summary="Automatically replace synonyms with the accepted name"
                android:defaultValue="true" />

            <ListPreference
                android:key="preferred_species_language"
                android:title="Target Language"
                android:summary="Translate lookup to this language"
                android:entries="@array/language_names"
                android:entryValues="@array/language_values"
                android:defaultValue="sv" />
        </PreferenceCategory>

        <CheckBoxPreference
            android:key="show_locality_description"
            android:title="Locality"
            android:summary="An text that describes where the collection/observation is done, should be written so it's possible to figure out the location from a map"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_substrate_field"
            android:title="Substrate"
            android:summary="Show field for the substrate"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_habitat_field"
            android:title="Habitat"
            android:summary="Show field for habitat/biotope"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_collector_field"
            android:title="Collector"
            android:summary="Show field for Collector(s) / Observer(s)"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_is_collection"
            android:title="Is collection and collection nr"
            android:summary="show Collection nr to connect data to the physical specimen"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="last_specimen_number"
            android:title="Next Specimen Number"
            android:defaultValue="1"
            android:summary="Manually set the next number to be used"
            android:dialogTitle="Set Next Number"
            android:selectAllOnFocus="true"
            android:inputType="number" />

    </PreferenceCategory>

    <PreferenceCategory android:title="Utilities">

        <CheckBoxPreference
            android:key="show_map_link"
            android:title="Map Button"
            android:summary="Button that links to Lantmäteriets Min Karta"
            android:defaultValue="true" />

        <CheckBoxPreference
            android:key="show_photo"
            android:title="Photo Button"
            android:summary="Show Photo button and gallery"
            android:defaultValue="true" />

    </PreferenceCategory>

</PreferenceScreen>